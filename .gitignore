# .gitignore reestruturado e comentado em pt-br
# Objetivo: evitar commit de artefatos locais, arquivos gerados e ambientes virtuais.

# -------------------------
# Backend (Python)
# -------------------------
# ambiente virtual local do backend
/backend/.venv/
backend/.venv/
/backend/.SkyNet-Mobile-VENV/
backend/.SkyNet-Mobile-VENV/
backend/SkyNet-Mobile/

# variáveis de ambiente
backend/.env
.env
.env.*

# caches e artefatos de teste/coverage
backend/.pytest_cache/
.pytest_cache/
backend/.coverage
.coverage
htmlcov/

# cache do ruff e artefatos do linter/formatador
backend/.ruff_cache/
.ruff_cache/

# diretórios de bytecode / cache
__pycache__/
backend/__pycache__/
*.py[cod]
*.pyo
*.pyd

# SQL / DB local (ex.: sqlite)
db.sqlite3
db.sqlite3-journal

# -------------------------
# Distribuição / empacotamento
# -------------------------
build/
dist/
*.egg-info/
*.egg
wheels/
*.whl

# pip / installer logs
pip-log.txt
pip-delete-this-directory.txt

# -------------------------
# Ferramentas de teste / coverage / CI
# -------------------------
.nox/
.tox/
.coverage.*
.coverage
coverage.xml
nosetests.xml
.hypothesis/

# -------------------------
# Editor / IDE / SO
# -------------------------
# VSCode
.vscode/

# JetBrains / PyCharm
.idea/

# sistema operacional
.DS_Store
Thumbs.db

# -------------------------
# Node / Frontend
# -------------------------
frontend/node_modules/
frontend/dist/
dist/
.vite/

# caches do frontend / bundlers
*.tsbuildinfo
.nyc_output/
coverage/
*.lcov

# -------------------------
# Virtualenvs / ambientes
# -------------------------
# nomes comuns para ambientes locais
.env
.SkyNet-Mobile-VENV/
SkyNet-Mobile-VENV/
env/
ENV/
env.bak/
SkyNet-Mobile-VENV.bak/
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.pdm-python
.pixi

# PEP 582
__pypackages__/

# -------------------------
# Arquivos temporários / logs / misc
# -------------------------
*.log
*.tmp
*.swp
*.swo

# arquivos binários / extensões C
*.so

# -------------------------
# Ferramentas específicas / caches
# -------------------------
.mypy_cache/
.pyre/
.pytype/
.dmypy.json
.dmypy.json

# Ruff cache (duplicado intencional: ponto geral e backend específico)
.ruff_cache/

# Cursor / ferramentas AI
.cursorignore
.cursorindexingignore

# arquivos de build específicos
.Python
.installed.cfg
MANIFEST

# -------------------------
# Notas:
# - Mantenha padrões específicos de projeto (ex.: backend/SkyNet-Mobile/) para
#   evitar commitar ambientes criados localmente.
# - Se usar Poetry/Poetry.lock/poetry.lock, considere commitar o lockfile e
#   não ignorá-lo (comentado por padrão).
# -------------------------
