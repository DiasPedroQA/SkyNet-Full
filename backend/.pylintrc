[FORMAT]
max-line-length=120

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    too-many-arguments,
    too-many-instance-attributes,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-boolean-expressions,
    too-many-lines,
    line-too-long,
    too-few-public-methods

[MASTER]
ignore=.venv

[MESSAGES CONTROL]
# Ignora warnings específicos do Pydantic
disable=W0201,  # attribute-defined-outside-init
        E0402,  # relative-beyond-top-level

[IMPORTS]
# Permite importações relativas
allow-relative-imports=yes
