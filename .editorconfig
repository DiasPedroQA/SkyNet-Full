# EditorConfig é maneiro: https://editorconfig.org

root = true

# =========================
# Configurações Globais
# =========================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# =========================
# Python (Backend)
# =========================
[*.py]
indent_size = 4
indent_style = space
profile = black
max_line_length = 120

# =========================
# JavaScript/TypeScript (Frontend)
# =========================
[*.{js,jsx,ts,tsx}]
indent_size = 4
indent_style = space
max_line_length = 120
quote_type = single

# =========================
# JSON/YAML
# =========================
[*.{json,yml,yaml}]
indent_size = 4
indent_style = space

# =========================
# HTML/CSS
# =========================
[*.{html,css,scss}]
indent_size = 4
indent_style = space

# =========================
# Markdown
# =========================
[*.md]
trim_trailing_whitespace = false
indent_size = 4  # Markdown fica melhor com 2 espaços
max_line_length = 80  # Melhor para legibilidade

# =========================
# Shell Scripts
# =========================
[*.{sh,bash}]
indent_size = 4
indent_style = space

# =========================
# Makefile (requer tabs)
# =========================
[{Makefile,*.mk}]
indent_style = tab
indent_size = 4  # Visualmente 4, mas usa tabs

# =========================
# Docker
# =========================
[{Dockerfile,.dockerignore}]
indent_size = 4
indent_style = space

# =========================
# Git
# =========================
[.{gitignore,gitattributes}]
indent_size = 4
indent_style = space

# =========================
# Requirements TXT
# =========================
[requirements*.txt]
indent_size = 4
indent_style = space
